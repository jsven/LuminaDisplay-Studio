{
  "name": "lumina-studio-web",
  "private": true,
  "version": "0.1.0",
  "description": "React + R3F Amazon scene preview for LuminaDisplay Studio",
  "scripts": {
    "build": "npm run sync:scenes && vite build",
    "convert:webm": "node scripts/webm-to-mp4.js",
    "dev": "node scripts/run-preview.js",
    "export:preview": "npm run build && node scripts/export-preview-video.js",
    "start": "npm run build && node server.js",
    "sync:scenes": "node scripts/generate-scene-data.js && node scripts/generate-scene-data-07.js && node scripts/build-manifest.js"
  },
  "dependencies": {
    "@react-three/fiber": "^9.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.180.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "vite": "^7.0.0"
  }
}
